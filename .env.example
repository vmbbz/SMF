# Required — Deepgram API key for STT (Flux v2) and TTS (Aura 2)
DEEPGRAM_API_KEY=

# Required for LLM fighter mode — at least one
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Redis — required for multiplayer rooms, matchmaking queue, signaling
REDIS_URL=redis://localhost:6379

# Postgres — required for ELO ratings, leaderboard, match history
DATABASE_URL=postgresql://stick:fighter@localhost:5433/stickfighter

# OAuth login (optional — leaderboard tracking requires login)
# dev       https://id.local.deepgram.com:4202
# staging   https://id.staging.dx.deepgram.com
# production  https://id.dx.deepgram.com
OIDC_ISSUER=https://id.local.deepgram.com:4202
OIDC_CLIENT_ID=stick-fighter
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://fight.local.deepgram.com:3007/auth/callback

# Required for Phone mode — Twilio call-in
TWILIO_PHONE_NUMBERS=+15551234567,+15551234568
BASE_URL=https://your-ngrok-url.ngrok.io

# Market Data APIs
BIRDEYE_API_KEY=
# Optional endpoint hardening:
# Prefix for market endpoints consumed by app clients.
SMF_MARKET_API_PREFIX=/api/marketfeed/v2
# Keep legacy endpoints (/api/trending, /api/graduates, /api/token/{mint}) disabled by default.
SMF_ALLOW_LEGACY_MARKET_ENDPOINTS=0

# Solana boost economy
# Single mint switch: replace this one value with the real $XXX mint after token launch.
SMF_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
BOOST_PAYMENT_TOKEN_SYMBOL=USDC
BOOST_PAYMENT_TOKEN_PRICE_FALLBACK=1
# Optional: fixed quote price for stablecoin payment smoke tests. Remove for live $XXX pricing.
# BOOST_PAYMENT_TOKEN_FIXED_PRICE_USD=1
# Production defaults. For a tiny mainnet smoke test only, set BOOST_MICRO_USD_CENTS=1 locally.
BOOST_MICRO_USD_CENTS=100
BOOST_DEGEN_USD_CENTS=300
BOOST_CHAOS_USD_CENTS=500
# Recommended: private provider endpoint (e.g. Alchemy) instead of shared public RPC.
SOLANA_RPC=https://solana-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# Public/client-safe RPC URL returned to browsers/mobile WebView.
SOLANA_RPC_PUBLIC=https://api.mainnet-beta.solana.com
STARTER_BOOSTS=15
BOOST_INTENT_TTL_SECONDS=600
WALLET_AUTH_CHALLENGE_TTL_SECONDS=300
WALLET_AUTH_SESSION_TTL_SECONDS=86400

# Android Digital Asset Links identity. Override only if package name or signing key changes.
ANDROID_APP_PACKAGE_NAME=com.solanamemefighter.app
ANDROID_APP_SHA256_CERT_FINGERPRINT=84:86:97:57:2F:90:2C:DC:01:7B:30:C3:87:D3:D2:A8:8D:47:E4:11:CA:B9:54:BA:B1:05:95:98:9D:DE:1D:76
